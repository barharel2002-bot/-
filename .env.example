# =============================================
# קובץ דוגמה למפתחות סביבה
# העתק את הקובץ הזה ל-.env.local ומלא את הערכים
# לעולם אל תעלה .env.local ל-Git!
# =============================================

# ----- Supabase -----
# מ-Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Anthropic Claude API -----
# מ-console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ----- YouTube Data API v3 -----
# מ-Google Cloud Console → APIs & Services → Credentials → API key
YOUTUBE_API_KEY=

# ----- Google OAuth (לחיבור ערוץ YouTube אישי לאנליטיקה) -----
# מ-Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# סוג: Web application. Redirect URI: http://localhost:3000/api/oauth/youtube/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ----- Meta (Instagram) OAuth — אופציונלי, דורש App Review -----
# מ-developers.facebook.com → My Apps → Create App
META_APP_ID=
META_APP_SECRET=

# ----- TikTok OAuth — אופציונלי, דורש App Review -----
# מ-developers.tiktok.com → Manage Apps
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ----- OpenAI Whisper (לתמלול הקלטות קוליות) -----
# מ-platform.openai.com → API keys
OPENAI_API_KEY=

# ----- Web Push VAPID keys -----
# צור עם: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
